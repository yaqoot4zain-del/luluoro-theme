{% extends "layouts.master" %}

{% block content %}
<div class="container mx-auto px-4 py-12">
  <h1 class="text-3xl font-bold mb-8">{{ 'my_account'|trans }}</h1>
  
  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Sidebar -->
    <div class="lg:w-64">
      <div class="bg-white rounded-lg shadow-sm p-6">
        <!-- User Info -->
        <div class="flex items-center gap-4 mb-6 pb-6 border-b border-gray-200">
          <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center text-white text-2xl font-bold">
            {{ customer.first_name|default(customer.name)|slice(0, 1)|upper }}
          </div>
          <div>
            <p class="font-semibold">{{ customer.name }}</p>
            <p class="text-sm text-gray-500">{{ customer.email }}</p>
          </div>
        </div>
        
        <!-- Navigation -->
        <nav class="space-y-2">
          <a href="{{ url('profile') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg bg-primary bg-opacity-10 text-primary">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            {{ 'dashboard'|trans }}
          </a>
          <a href="{{ url('orders') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 text-gray-700">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            {{ 'my_orders'|trans }}
          </a>
          <a href="{{ url('addresses') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 text-gray-700">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            {{ 'addresses'|trans }}
          </a>
          <a href="{{ url('wishlist') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 text-gray-700">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
            {{ 'wishlist'|trans }}
          </a>
          <a href="{{ url('logout') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 text-red-600">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            {{ 'logout'|trans }}
          </a>
        </nav>
      </div>
    </div>
    
    <!-- Main Content -->
    <div class="flex-1">
      <!-- Welcome Message -->
      <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
        <h2 class="text-xl font-bold mb-2">{{ 'welcome_back'|trans }}, {{ customer.first_name|default(customer.name) }}!</h2>
        <p class="text-gray-500">{{ 'account_overview'|trans }}</p>
      </div>
      
      <!-- Quick Stats -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
        <a href="{{ url('orders') }}" class="bg-white rounded-lg shadow-sm p-6 hover:shadow-md transition">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
            </div>
            <div>
              <p class="text-2xl font-bold">{{ customer.orders_count|default(0) }}</p>
              <p class="text-sm text-gray-500">{{ 'orders'|trans }}</p>
            </div>
          </div>
        </a>
        
        <a href="{{ url('wishlist') }}" class="bg-white rounded-lg shadow-sm p-6 hover:shadow-md transition">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-2xl font-bold">{{ wishlist_count|default(0) }}</p>
              <p class="text-sm text-gray-500">{{ 'wishlist_items'|trans }}</p>
            </div>
          </div>
        </a>
        
        <a href="{{ url('addresses') }}" class="bg-white rounded-lg shadow-sm p-6 hover:shadow-md transition">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-2xl font-bold">{{ customer.addresses_count|default(0) }}</p>
              <p class="text-sm text-gray-500">{{ 'saved_addresses'|trans }}</p>
            </div>
          </div>
        </a>
      </div>
      
      <!-- Recent Orders -->
      <div class="bg-white rounded-lg shadow-sm p-6">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-bold">{{ 'recent_orders'|trans }}</h3>
          <a href="{{ url('orders') }}" class="text-primary hover:underline text-sm">{{ 'view_all'|trans }}</a>
        </div>
        
        {% if customer.recent_orders|default([])|length > 0 %}
          <div class="space-y-4">
            {% for order in customer.recent_orders %}
              <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg">
                <div>
                  <p class="font-semibold">#{{ order.number }}</p>
                  <p class="text-sm text-gray-500">{{ order.date|date('M d, Y') }}</p>
                </div>
                <div>
                  <p class="font-semibold">{{ order.total|money }}</p>
                  <p class="text-sm">
                    <span class="px-2 py-1 rounded text-xs
                      {% if order.status == 'completed' %}bg-green-100 text-green-800
                      {% elseif order.status == 'processing' %}bg-blue-100 text-blue-800
                      {% elseif order.status == 'pending' %}bg-yellow-100 text-yellow-800
                      {% else %}bg-gray-100 text-gray-800{% endif %}
                    ">
                      {{ order.status|trans }}
                    </span>
                  </p>
                </div>
                <a href="{{ url('orders/' ~ order.id) }}" class="text-primary hover:underline">
                  {{ 'view_details'|trans }}
                </a>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <p class="text-gray-500 text-center py-8">{{ 'no_orders_yet'|trans }}</p>
          <div class="text-center">
            <a href="{{ url('products') }}" class="inline-block bg-primary text-white px-6 py-2 rounded-lg hover:bg-opacity-90 transition">
              {{ 'start_shopping'|trans }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>
{% endblock %}
