{% extends "layouts.master" %}

{% block content %}
<div class="container mx-auto px-4 py-12">
  <h1 class="text-3xl font-bold mb-8 text-center">{{ 'shopping_cart'|trans }}</h1>
  
  {% if cart.items|length > 0 %}
    <div class="flex flex-col lg:flex-row gap-12">
      <!-- Cart Items -->
      <div class="flex-1">
        <div class="bg-white rounded-lg shadow-sm overflow-hidden">
          {% for item in cart.items %}
            <div class="flex items-center gap-4 p-4 border-b border-gray-200">
              <a href="{{ item.product.url }}">
                <img 
                  src="{{ item.product.image }}" 
                  alt="{{ item.product.name }}" 
                  class="w-24 h-24 object-cover rounded"
                >
              </a>
              <div class="flex-1">
                <a href="{{ item.product.url }}" class="font-semibold hover:text-primary">
                  {{ item.product.name }}
                </a>
                {% if item.product.sku %}
                  <p class="text-sm text-gray-500">{{ 'sku'|trans }}: {{ item.product.sku }}</p>
                {% endif %}
                <div class="flex items-center gap-4 mt-2">
                  <!-- Quantity -->
                  <div class="flex items-center border border-gray-300 rounded">
                    <button 
                      class="px-3 py-1 hover:bg-gray-100"
                      onclick="salla.cart.update({{ item.id }}, {{ item.quantity - 1 }});"
                    >
                      -
                    </button>
                    <span class="px-3 py-1">{{ item.quantity }}</span>
                    <button 
                      class="px-3 py-1 hover:bg-gray-100"
                      onclick="salla.cart.update({{ item.id }}, {{ item.quantity + 1 }});"
                    >
                      +
                    </button>
                  </div>
                  <span class="text-primary font-bold">{{ item.total|money }}</span>
                </div>
              </div>
              <button 
                class="text-gray-400 hover:text-red-500 transition"
                onclick="salla.cart.remove({{ item.id }});"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              </button>
            </div>
          {% endfor %}
        </div>
        
        <!-- Continue Shopping -->
        <div class="mt-6">
          <a href="{{ url('products') }}" class="text-primary hover:underline flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            {{ 'continue_shopping'|trans }}
          </a>
        </div>
      </div>
      
      <!-- Cart Summary -->
      <div class="lg:w-96">
        <div class="bg-white rounded-lg shadow-sm p-6 sticky top-24">
          <h2 class="text-xl font-bold mb-6">{{ 'cart_summary'|trans }}</h2>
          
          <div class="space-y-3 border-b border-gray-200 pb-6 mb-6">
            <div class="flex justify-between">
              <span class="text-gray-600">{{ 'subtotal'|trans }}</span>
              <span class="font-semibold">{{ cart.subtotal|money }}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">{{ 'shipping'|trans }}</span>
              <span class="font-semibold">{{ cart.shipping|money }}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">{{ 'tax'|trans }}</span>
              <span class="font-semibold">{{ cart.tax|money }}</span>
            </div>
          </div>
          
          <div class="flex justify-between mb-6">
            <span class="text-lg font-bold">{{ 'total'|trans }}</span>
            <span class="text-lg font-bold text-primary">{{ cart.total|money }}</span>
          </div>
          
          <a 
            href="{{ url('checkout') }}" 
            class="block w-full bg-primary text-white text-center py-3 rounded-lg font-semibold hover:bg-opacity-90 transition"
          >
            {{ 'proceed_to_checkout'|trans }}
          </a>
          
          <!-- Trusted Payment Icons -->
          <div class="mt-6 text-center">
            <p class="text-sm text-gray-500 mb-2">{{ 'secure_checkout'|trans }}</p>
            <div class="flex justify-center gap-2">
              <!-- Visa -->
              <div class="bg-gray-100 px-2 py-1 rounded text-xs font-bold">VISA</div>
              <!-- Mastercard -->
              <div class="bg-gray-100 px-2 py-1 rounded text-xs font-bold">MC</div>
              <!-- Amex -->
              <div class="bg-gray-100 px-2 py-1 rounded text-xs font-bold">AMEX</div>
              <!-- Mada -->
              <div class="bg-gray-100 px-2 py-1 rounded text-xs font-bold">MADA</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  {% else %}
    <!-- Empty Cart -->
    <div class="text-center py-16">
      <svg class="w-24 h-24 mx-auto text-gray-300 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
      </svg>
      <h2 class="text-2xl font-bold mb-4">{{ 'your_cart_is_empty'|trans }}</h2>
      <p class="text-gray-500 mb-8">{{ 'looks_like_you_havent_added'|trans }}</p>
      <a 
        href="{{ url('products') }}" 
        class="inline-block bg-primary text-white px-8 py-3 rounded-lg font-semibold hover:bg-opacity-90 transition"
      >
        {{ 'start_shopping'|trans }}
      </a>
    </div>
  {% endif %}
</div>
{% endblock %}
