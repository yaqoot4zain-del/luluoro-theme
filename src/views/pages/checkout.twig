{% extends "layouts.master" %}

{% block content %}
<div class="container mx-auto px-4 py-12">
  <h1 class="text-3xl font-bold mb-8 text-center">{{ 'checkout'|trans }}</h1>
  
  {% if cart.items|length > 0 %}
    <div class="flex flex-col lg:flex-row gap-12">
      <!-- Checkout Form -->
      <div class="flex-1">
        <form id="checkout-form" method="post" action="{{ url('checkout') }}">
          <!-- Contact Information -->
          <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
            <h2 class="text-xl font-bold mb-4">{{ 'contact_information'|trans }}</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'email'|trans }}</label>
                <input 
                  type="email" 
                  name="email" 
                  value="{{ customer.email|default('') }}"
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                >
              </div>
              <div class="flex items-center gap-2">
                <input type="checkbox" id="newsletter" name="newsletter" class="rounded text-primary">
                <label for="newsletter" class="text-sm text-gray-600">{{ 'subscribe_newsletter'|trans }}</label>
              </div>
            </div>
          </div>
          
          <!-- Shipping Address -->
          <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
            <h2 class="text-xl font-bold mb-4">{{ 'shipping_address'|trans }}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'first_name'|trans }}</label>
                <input 
                  type="text" 
                  name="first_name" 
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                >
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'last_name'|trans }}</label>
                <input 
                  type="text" 
                  name="last_name" 
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                >
              </div>
              <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'address'|trans }}</label>
                <input 
                  type="text" 
                  name="address" 
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                >
              </div>
              <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'apartment'|trans }} ({{ 'optional'|trans }})</label>
                <input 
                  type="text" 
                  name="apartment" 
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                >
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'city'|trans }}</label>
                <input 
                  type="text" 
                  name="city" 
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                >
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'phone'|trans }}</label>
                <input 
                  type="tel" 
                  name="phone" 
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                >
              </div>
            </div>
          </div>
          
          <!-- Shipping Method -->
          <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
            <h2 class="text-xl font-bold mb-4">{{ 'shipping_method'|trans }}</h2>
            <div class="space-y-3">
              <label class="flex items-center justify-between p-4 border border-gray-200 rounded-lg cursor-pointer hover:border-primary transition">
                <div class="flex items-center gap-3">
                  <input type="radio" name="shipping_method" value="standard" checked class="text-primary">
                  <div>
                    <p class="font-medium">{{ 'standard_shipping'|trans }}</p>
                    <p class="text-sm text-gray-500">{{ 'standard_shipping_time'|trans }}</p>
                  </div>
                </div>
                <span class="font-semibold">{{ 'free'|trans }}</span>
              </label>
              <label class="flex items-center justify-between p-4 border border-gray-200 rounded-lg cursor-pointer hover:border-primary transition">
                <div class="flex items-center gap-3">
                  <input type="radio" name="shipping_method" value="express" class="text-primary">
                  <div>
                    <p class="font-medium">{{ 'express_shipping'|trans }}</p>
                    <p class="text-sm text-gray-500">{{ 'express_shipping_time'|trans }}</p>
                  </div>
                </div>
                <span class="font-semibold">{{ 'express_shipping_price'|trans }}</span>
              </label>
            </div>
          </div>
          
          <!-- Payment -->
          <div class="bg-white rounded-lg shadow-sm p-6">
            <h2 class="text-xl font-bold mb-4">{{ 'payment'|trans }}</h2>
            <div class="space-y-3">
              <label class="flex items-center gap-3 p-4 border border-primary rounded-lg bg-primary bg-opacity-5">
                <input type="radio" name="payment_method" value="card" checked class="text-primary">
                <span class="font-medium">{{ 'credit_card'|trans }}</span>
              </label>
              <label class="flex items-center gap-3 p-4 border border-gray-200 rounded-lg cursor-pointer hover:border-primary transition">
                <input type="radio" name="payment_method" value="cod" class="text-primary">
                <span class="font-medium">{{ 'cash_on_delivery'|trans }}</span>
              </label>
            </div>
            
            <!-- Card Details (shown when credit card is selected) -->
            <div id="card-details" class="mt-4 space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'card_number'|trans }}</label>
                <input 
                  type="text" 
                  name="card_number" 
                  placeholder="**** **** **** ****"
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                >
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'expiry_date'|trans }}</label>
                  <input 
                    type="text" 
                    name="expiry" 
                    placeholder="MM/YY"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                  >
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'cvv'|trans }}</label>
                  <input 
                    type="text" 
                    name="cvv" 
                    placeholder="***"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                  >
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'name_on_card'|trans }}</label>
                <input 
                  type="text" 
                  name="card_name" 
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                >
              </div>
            </div>
          </div>
        </form>
      </div>
      
      <!-- Order Summary -->
      <div class="lg:w-96">
        <div class="bg-white rounded-lg shadow-sm p-6 sticky top-24">
          <h2 class="text-xl font-bold mb-6">{{ 'order_summary'|trans }}</h2>
          
          <!-- Cart Items -->
          <div class="space-y-4 mb-6 max-h-64 overflow-y-auto">
            {% for item in cart.items %}
              <div class="flex gap-3">
                <div class="relative">
                  <img 
                    src="{{ item.product.image }}" 
                    alt="{{ item.product.name }}" 
                    class="w-16 h-16 object-cover rounded"
                  >
                  <span class="absolute -top-2 -right-2 bg-gray-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center">
                    {{ item.quantity }}
                  </span>
                </div>
                <div class="flex-1">
                  <p class="font-medium text-sm">{{ item.product.name }}</p>
                  <p class="text-primary text-sm font-semibold">{{ item.total|money }}</p>
                </div>
              </div>
            {% endfor %}
          </div>
          
          <!-- Discount Code -->
          <div class="mb-6">
            <div class="flex gap-2">
              <input 
                type="text" 
                name="discount_code" 
                placeholder="{{ 'discount_code'|trans }}"
                class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-sm"
              >
              <button 
                type="button"
                class="px-4 py-2 border border-primary text-primary rounded-lg hover:bg-primary hover:text-white transition text-sm"
              >
                {{ 'apply'|trans }}
              </button>
            </div>
          </div>
          
          <!-- Totals -->
          <div class="space-y-3 border-t border-gray-200 pt-4">
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">{{ 'subtotal'|trans }}</span>
              <span>{{ cart.subtotal|money }}</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">{{ 'shipping'|trans }}</span>
              <span>{{ 'calculated_next_step'|trans }}</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">{{ 'tax'|trans }}</span>
              <span>{{ cart.tax|money }}</span>
            </div>
          </div>
          
          <div class="flex justify-between border-t border-gray-200 pt-4 mt-4">
            <span class="text-lg font-bold">{{ 'total'|trans }}</span>
            <span class="text-lg font-bold text-primary">{{ cart.total|money }}</span>
          </div>
          
          <button 
            type="submit" 
            form="checkout-form"
            class="w-full bg-primary text-white py-4 rounded-lg font-semibold hover:bg-opacity-90 transition mt-6"
          >
            {{ 'place_order'|trans }}
          </button>
          
          <!-- Trusted Payment -->
          <div class="mt-4 text-center">
            <p class="text-xs text-gray-500">{{ 'secure_checkout_text'|trans }}</p>
          </div>
        </div>
      </div>
    </div>
  {% else %}
    <!-- Empty Cart Redirect -->
    <div class="text-center py-16">
      <h2 class="text-2xl font-bold mb-4">{{ 'cart_is_empty'|trans }}</h2>
      <a href="{{ url('products') }}" class="text-primary hover:underline">{{ 'continue_shopping'|trans }}</a>
    </div>
  {% endif %}
</div>

<script>
  // Toggle card details based on payment method
  document.querySelectorAll('input[name="payment_method"]').forEach(radio => {
    radio.addEventListener('change', function() {
      const cardDetails = document.getElementById('card-details');
      if (cardDetails) {
        cardDetails.style.display = this.value === 'card' ? 'block' : 'none';
      }
    });
  });
</script>
{% endblock %}
