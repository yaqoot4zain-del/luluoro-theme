{% extends "layouts.master" %}

{% block content %}
<div class="container mx-auto px-4 py-16">
  <h1 class="text-4xl font-bold text-center mb-4">{{ 'contact_us'|trans }}</h1>
  <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">{{ 'contact_page_desc'|trans }}</p>
  
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
    <!-- Contact Form -->
    <div class="bg-white rounded-lg shadow-sm p-8">
      <h2 class="text-2xl font-bold mb-6">{{ 'send_message'|trans }}</h2>
      <form action="{{ url('contact/submit') }}" method="post" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'first_name'|trans }}</label>
            <input 
              type="text" 
              name="first_name" 
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
            >
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'last_name'|trans }}</label>
            <input 
              type="text" 
              name="last_name" 
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
            >
          </div>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'email'|trans }}</label>
          <input 
            type="email" 
            name="email" 
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
          >
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'phone'|trans }}</label>
          <input 
            type="tel" 
            name="phone" 
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
          >
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'subject'|trans }}</label>
          <select 
            name="subject" 
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
          >
            <option value="">{{ 'select_subject'|trans }}</option>
            <option value="order">{{ 'order_inquiry'|trans }}</option>
            <option value="product">{{ 'product_question'|trans }}</option>
            <option value="return">{{ 'return_request'|trans }}</option>
            <option value="partnership">{{ 'partnership'|trans }}</option>
            <option value="other">{{ 'other'|trans }}</option>
          </select>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ 'message'|trans }}</label>
          <textarea 
            name="message" 
            rows="5" 
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
          ></textarea>
        </div>
        
        <button 
          type="submit" 
          class="w-full bg-primary text-white py-3 rounded-lg font-semibold hover:bg-opacity-90 transition"
        >
          {{ 'send'|trans }}
        </button>
      </form>
    </div>
    
    <!-- Contact Info -->
    <div>
      <!-- Contact Details -->
      <div class="bg-white rounded-lg shadow-sm p-8 mb-6">
        <h2 class="text-2xl font-bold mb-6">{{ 'contact_information'|trans }}</h2>
        
        <div class="space-y-4">
          {% if store.email %}
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-primary bg-opacity-10 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="font-medium">{{ 'email'|trans }}</p>
                <a href="mailto:{{ store.email }}" class="text-primary hover:underline">{{ store.email }}</a>
              </div>
            </div>
          {% endif %}
          
          {% if store.phone %}
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-primary bg-opacity-10 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="font-medium">{{ 'phone'|trans }}</p>
                <a href="tel:{{ store.phone }}" class="text-primary hover:underline">{{ store.phone }}</a>
              </div>
            </div>
          {% endif %}
          
          {% if store.address %}
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-primary bg-opacity-10 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-medium">{{ 'address'|trans }}</p>
                <p class="text-gray-600">{{ store.address }}</p>
              </div>
            </div>
          {% endif %}
        </div>
        
        <!-- Social Media -->
        <div class="mt-8 pt-6 border-t border-gray-200">
          <p class="font-medium mb-4">{{ 'follow_us'|trans }}</p>
          <div class="flex gap-4">
            <a href="https://instagram.com/lulu.oro" target="_blank" class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-primary hover:text-white transition">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
            <a href="https://tiktok.com/@luluorojewelry" target="_blank" class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-primary hover:text-white transition">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
            </a>
            <a href="https://snapchat.com/add/luluoro_lo" target="_blank" class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-primary hover:text-white transition">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.206.793c.99 0 5.877.385 7.186 2.634.523.901.76 1.985.76 3.213 0 .613-.083 1.21-.234 1.785-.32 1.226-.972 2.351-1.916 3.301-.737.744-1.611 1.286-2.578 1.594.625.18 1.185.467 1.662.846.717.571 1.19 1.354 1.328 2.202.06.36.03.726-.09 1.085-.18.54-.525 1.033-.999 1.436-.395.336-.868.576-1.39.707-.33.083-.67.125-1.015.125-.405 0-.81-.06-1.2-.18-.96-.298-1.755-.877-2.304-1.643-.405-.565-.66-1.225-.752-1.936-.03-.255-.02-.514.03-.77.12-.765.42-1.485.87-2.115-1.155-1.035-1.755-2.34-1.755-3.795 0-1.065.315-2.06.88-2.876.6-.866 1.47-1.522 2.53-1.904-.195-.6-.29-1.235-.29-1.89 0-1.305.45-2.509 1.22-3.49.255-.328.555-.62.885-.885z"/></svg>
            </a>
          </div>
        </div>
      </div>
      
      <!-- Business Hours -->
      <div class="bg-white rounded-lg shadow-sm p-8">
        <h2 class="text-2xl font-bold mb-6">{{ 'business_hours'|trans }}</h2>
        <div class="space-y-3">
          <div class="flex justify-between">
            <span class="text-gray-600">{{ 'sunday_thursday'|trans }}</span>
            <span class="font-medium">9:00 AM - 9:00 PM</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">{{ 'friday'|trans }}</span>
            <span class="font-medium">2:00 PM - 9:00 PM</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">{{ 'saturday'|trans }}</span>
            <span class="font-medium">10:00 AM - 9:00 PM</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
