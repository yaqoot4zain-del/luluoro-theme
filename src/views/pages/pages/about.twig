{% extends "layouts.master" %}

{% block content %}
<div class="container mx-auto px-4 py-16">
  <h1 class="text-4xl font-bold text-center mb-4">{{ 'about_us'|trans }}</h1>
  <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">{{ store.description }}</p>
  
  <!-- Main About Content -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
    <div>
      <img 
        src="https://luluoro.com/cdn/shop/files/4W2A4575-min.jpg?v=1748896198&width=1200" 
        alt="LuluOro Jewelry" 
        class="w-full rounded-lg shadow-lg"
      >
    </div>
    <div>
      <h2 class="text-2xl font-bold mb-4">{{ 'our_story'|trans }}</h2>
      <p class="text-gray-600 mb-4">
        {{ 'our_story_text'|trans }}
      </p>
      <p class="text-gray-600 mb-6">
        {{ 'our_story_text_2'|trans }}
      </p>
    </div>
  </div>
  
  <!-- Values Section -->
  <div class="bg-gray-50 rounded-lg p-8 mb-16">
    <h2 class="text-2xl font-bold text-center mb-8">{{ 'our_values'|trans }}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 438 0 3.42 3.42 0 001.0 014.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
          </svg>
        </div>
        <h3 class="font-bold text-lg mb-2">{{ 'quality'|trans }}</h3>
        <p class="text-gray-600 text-sm">{{ 'quality_desc'|trans }}</p>
      </div>
      
      <div class="text-center">
        <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="font-bold text-lg mb-2">{{ 'value'|trans }}</h3>
        <p class="text-gray-600 text-sm">{{ 'value_desc'|trans }}</p>
      </div>
      
      <div class="text-center">
        <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
        </div>
        <h3 class="font-bold text-lg mb-2">{{ 'love'|trans }}</h3>
        <p class="text-gray-600 text-sm">{{ 'love_desc'|trans }}</p>
      </div>
    </div>
  </div>
  
  <!-- Testimonials -->
  <div class="mb-16">
    <h2 class="text-2xl font-bold text-center mb-8">{{ 'what_customers_say'|trans }}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div class="bg-white p-6 rounded-lg shadow-sm">
        <div class="flex text-primary mb-4">
          {% for i in 1..5 %}
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {% endfor %}
        </div>
        <p class="text-gray-600 mb-4">"{{ 'testimonial_1_text'|trans }}"</p>
        <p class="font-semibold">{{ 'testimonial_1_author'|trans }}</p>
      </div>
      
      <div class="bg-white p-6 rounded-lg shadow-sm">
        <div class="flex text-primary mb-4">
          {% for i in 1..5 %}
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {% endfor %}
        </div>
        <p class="text-gray-600 mb-4">"{{ 'testimonial_2_text'|trans }}"</p>
        <p class="font-semibold">{{ 'testimonial_2_author'|trans }}</p>
      </div>
      
      <div class="bg-white p-6 rounded-lg shadow-sm">
        <div class="flex text-primary mb-4">
          {% for i in 1..5 %}
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {% endfor %}
        </div>
        <p class="text-gray-600 mb-4">"{{ 'testimonial_3_text'|trans }}"</p>
        <p class="font-semibold">{{ 'testimonial_3_author'|trans }}</p>
      </div>
    </div>
  </div>
  
  <!-- Contact CTA -->
  <div class="text-center">
    <h2 class="text-2xl font-bold mb-4">{{ 'get_in_touch'|trans }}</h2>
    <p class="text-gray-600 mb-6">{{ 'contact_subtitle'|trans }}</p>
    <a 
      href="{{ url('pages/contact') }}" 
      class="inline-block bg-primary text-white px-8 py-3 rounded-lg font-semibold hover:bg-opacity-90 transition"
    >
      {{ 'contact_us'|trans }}
    </a>
  </div>
</div>
{% endblock %}
