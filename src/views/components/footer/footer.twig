{# Footer Component #}
<footer class="bg-secondary text-white pt-16 pb-8">
  <div class="container mx-auto px-4">
    <!-- Newsletter Section -->
    <div class="mb-12 text-center">
      <h3 class="text-2xl font-bold mb-4">{{ 'insiders_club'|trans }}</h3>
      <p class="text-gray-300 mb-6 max-w-xl mx-auto">{{ 'newsletter_text'|trans }}</p>
      <form action="{{ url('newsletter/subscribe') }}" method="post" class="max-w-md mx-auto flex gap-2">
        <input 
          type="email" 
          name="email" 
          placeholder="{{ 'email_placeholder'|trans }}"
          required
          class="flex-1 px-4 py-3 rounded-lg bg-white text-gray-800 focus:outline-none focus:ring-2 focus:ring-primary"
        >
        <button 
          type="submit" 
          class="bg-primary text-white px-6 py-3 rounded-lg hover:bg-opacity-90 transition font-semibold"
        >
          {{ 'subscribe'|trans }}
        </button>
      </form>
    </div>

    <!-- Main Footer Links -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      <!-- About -->
      <div>
        <h4 class="font-bold mb-4 text-lg">{{ 'about'|trans }}</h4>
        <ul class="space-y-2">
          <li><a href="{{ url('pages/find-us-at') }}" class="text-gray-300 hover:text-primary transition">{{ 'find_us_at'|trans }}</a></li>
          <li><a href="{{ url('policies/shipping-policy') }}" class="text-gray-300 hover:text-primary transition">{{ 'shipping_policy'|trans }}</a></li>
          <li><a href="{{ url('policies/privacy-policy') }}" class="text-gray-300 hover:text-primary transition">{{ 'privacy_policy'|trans }}</a></li>
          <li><a href="{{ url('policies/terms-of-service') }}" class="text-gray-300 hover:text-primary transition">{{ 'terms_of_service'|trans }}</a></li>
        </ul>
      </div>

      <!-- Customer Service -->
      <div>
        <h4 class="font-bold mb-4 text-lg">{{ 'customer_service'|trans }}</h4>
        <ul class="space-y-2">
          <li><a href="{{ url('pages/contact') }}" class="text-gray-300 hover:text-primary transition">{{ 'contact'|trans }}</a></li>
          <li><a href="{{ url('pages/ring-size-guide') }}" class="text-gray-300 hover:text-primary transition">{{ 'ring_size_guide'|trans }}</a></li>
          <li><a href="{{ url('policies/refund-policy') }}" class="text-gray-300 hover:text-primary transition">{{ 'returns_exchanges'|trans }}</a></li>
          <li><a href="{{ url('pages/faqs') }}" class="text-gray-300 hover:text-primary transition">{{ 'faqs'|trans }}</a></li>
        </ul>
      </div>

      <!-- Partner With Us -->
      <div>
        <h4 class="font-bold mb-4 text-lg">{{ 'partner_with_us'|trans }}</h4>
        <ul class="space-y-2">
          <li><a href="{{ url('pages/collab') }}" class="text-gray-300 hover:text-primary transition">{{ 'ambassadors'|trans }}</a></li>
          <li><a href="https://docs.google.com/forms/d/e/1FAIpQLSdA-lA3r1WRknfUSzry4_EPGMQ9-_ShOWSH5zK2jY5WVWBjnA/viewform" target="_blank" class="text-gray-300 hover:text-primary transition">{{ 'retailers'|trans }}</a></li>
          <li><a href="https://docs.google.com/forms/d/e/1FAIpQLSdweSAUvkdnLRK95kwDbEVpmQiP7tAySE5DBdRM8RuOOWsl5Q/viewform" target="_blank" class="text-gray-300 hover:text-primary transition">{{ 'wholesale_inquiries'|trans }}</a></li>
          <li><a href="https://docs.google.com/forms/d/e/1FAIpQLSc9xvt4DNfQWMdOvsIfGt8r72WhSrs0kkpNxB4yDl8ozNP1Yg/viewform" target="_blank" class="text-gray-300 hover:text-primary transition">{{ 'affiliates'|trans }}</a></li>
        </ul>
      </div>

      <!-- Categories -->
      <div>
        <h4 class="font-bold mb-4 text-lg">{{ 'categories'|trans }}</h4>
        <ul class="space-y-2">
          <li><a href="{{ url('collections/desert-island') }}" class="text-gray-300 hover:text-primary transition">{{ 'desert_island'|trans }}</a></li>
          <li><a href="{{ url('collections/desert-island-part-two') }}" class="text-gray-300 hover:text-primary transition">{{ 'desert_island_2'|trans }}</a></li>
          <li><a href="{{ url('collections/lo-iconics') }}" class="text-gray-300 hover:text-primary transition">{{ 'luluoro_iconics'|trans }}</a></li>
        </ul>
      </div>
    </div>

    <!-- Social Icons -->
