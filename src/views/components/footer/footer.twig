    </div>

    <!-- Country/Language Selector -->
    <div class="flex justify-center gap-4 mb-8 text-sm text-gray-400">
      <div class="flex items-center gap-2">
        <span>{{ 'country'|trans }}:</span>
        <select class="bg-transparent border-none text-gray-300 focus:outline-none cursor-pointer">
          <option value="SA" selected>Saudi Arabia | SAR</option>
          <option value="BH">Bahrain | BHD</option>
          <option value="AE">United Arab Emirates | AED</option>
          <option value="KW">Kuwait | KWD</option>
          <option value="QA">Qatar | QAR</option>
        </select>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-gray-700 pt-8 text-center text-gray-400">
      <p>&copy; {{ "now"|date("Y") }} {{ store.name }}. {{ 'all_rights_reserved'|trans }}</p>
      <p class="mt-2 text-sm">
        <a href="https://sbmc.bh" target="_blank" class="hover:text-primary transition">{{ 'developed_by'|trans }}</a>
      </p>
    </div>
  </div>
</footer>
