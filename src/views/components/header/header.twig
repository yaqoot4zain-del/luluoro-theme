{# Header Component #}
<header class="bg-white shadow-md sticky top-0 z-50">
  <!-- Top Bar -->
  <div class="bg-secondary text-white text-xs py-2">
    <div class="container mx-auto px-4 flex justify-between items-center">
      <div class="flex items-center gap-4">
        <!-- Country Selector -->
        <div class="relative group">
          <button class="flex items-center gap-1 hover:text-primary transition">
            <span>{{ country.current.name }}</span>
            <span>|</span>
            <span>{{ country.current.currency }}</span>
          </button>
        </div>
        
        <!-- Language Selector -->
        <div class="relative group">
          <button class="hover:text-primary transition">
            {{ app.getLocale()|upper }}
          </button>
          <div class="absolute left-0 top-full mt-1 bg-white text-gray-800 shadow-lg rounded hidden group-hover:block min-w-[100px]">
            <a href="{{ url('/', {'lang': 'ar'}) }}" class="block px-4 py-2 hover:bg-gray-100">العربية</a>
            <a href="{{ url('/', {'lang': 'en'}) }}" class="block px-4 py-2 hover:bg-gray-100">English</a>
          </div>
        </div>
      </div>
      
      <!-- Social Icons -->
      <div class="flex items-center gap-3">
        <a href="https://instagram.com/lulu.oro" target="_blank" class="hover:text-primary transition">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href="https://tiktok.com/@luluorojewelry" target="_blank" class="hover:text-primary transition">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Main Header -->
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between py-4">
      <!-- Logo -->
      <a href="{{ url('/') }}" class="flex-shrink-0">
        {% if store.logo %}
          <img src="{{ store.logo }}" alt="{{ store.name }}" class="h-16">
        {% else %}
          <span class="text-2xl font-bold text-primary">{{ store.name }}</span>
        {% endif %}
      </a>

      <!-- Search Bar -->
      <form action="{{ url('products') }}" method="get" class="hidden md:block flex-1 max-w-md mx-8">
        <div class="relative">
          <input 
            type="text" 
            name="search" 
            placeholder="{{ 'search_placeholder'|trans }}" 
            class="w-full px-4 py-2 border border-gray-300 rounded-full focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
          >
          <button type="submit" class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-primary transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </button>
        </div>
      </form>

      <!-- Actions -->
      <div class="flex items-center gap-6">
        {% if customer %}
          <a href="{{ url('profile') }}" class="text-gray-700 hover:text-primary transition flex items-center gap-1">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <span class="hidden lg:inline">{{ 'profile'|trans }}</span>
          </a>
        {% else %}
          <a href="{{ url('login') }}" class="text-gray-700 hover:text-primary transition flex items-center gap-1">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <span class="hidden lg:inline">{{ 'login'|trans }}</span>
          </a>
        {% endif %}
        
        <a href="{{ url('wishlist') }}" class="text-gray-700 hover:text-primary transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
        </a>
        
        <a href="{{ url('cart') }}" class="text-gray-700 hover:text-primary transition relative">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          {% if cart.count > 0 %}
            <span class="absolute -top-2 -right-2 bg-primary text-white text-xs rounded-full w-5 h-5 flex items-center justify-center font-bold">
              {{ cart.count }}
            </span>
          {% endif %}
        </a>
        
        <!-- Mobile Menu Toggle -->
        <button id="mobile-menu-toggle" class="md:hidden text-gray-700 hover:text-primary transition">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>

    <!-- Navigation -->
    <nav class="py-3 border-t border-gray-200 hidden md:block">
      <ul class="flex justify-center items-center gap-8">
        <li>
          <a href="{{ url('products') }}" class="text-gray-700 hover:text-primary transition font-medium">
            {{ 'shop'|trans }}
          </a>
        </li>
        
        <!-- Collections Dropdown -->
        <li class="relative group">
          <button class="text-gray-700 hover:text-primary transition font-medium flex items-center gap-1">
            {{ 'collections'|trans }}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute left-0 top-full mt-1 bg-white shadow-lg rounded-lg py-2 min-w-[200px] hidden group-hover:block z-50">
            <a href="{{ url('collections/desert-island') }}" class="block px-4 py-2 hover:bg-gray-100 text-gray-700">{{ 'desert_island'|trans }}</a>
            <a href="{{ url('collections/desert-island-part-two') }}" class="block px-4 py-2 hover:bg-gray-100 text-gray-700">{{ 'desert_island_2'|trans }}</a>
            <a href="{{ url('collections/may-mini-drops') }}" class="block px-4 py-2 hover:bg-gray-100 text-gray-700">{{ 'mini_drops'|trans }}</a>
          </div>
        </li>
        
        <!-- By Type Dropdown -->
        <li class="relative group">
          <button class="text-gray-700 hover:text-primary transition font-medium flex items-center gap-1">
            {{ 'by_type'|trans }}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute left-0 top-full mt-1 bg-white shadow-lg rounded-lg py-2 min-w-[200px] hidden group-hover:block z-50">
            <a href="{{ url('collections/necklaces') }}" class="block px-4 py-2 hover:bg-gray-100 text-gray-700">{{ 'necklaces'|trans }}</a>
            <a href="{{ url('collections/rings') }}" class="block px-4 py-2 hover:bg-gray-100 text-gray-700">{{ 'rings'|trans }}</a>
            <a href="{{ url('collections/earrings') }}" class="block px-4 py-2 hover:bg-gray-100 text-gray-700">{{ 'earrings'|trans }}</a>
            <a href="{{ url('collections/bracelets') }}" class="block px-4 py-2 hover:bg-gray-100 text-gray-700">{{ 'bracelets'|trans }}</a>
          </div>
        </li>
        
        <li>
          <a href="{{ url('pages/about') }}" class="text-gray-700 hover:text-primary transition font-medium">
            {{ 'about_us'|trans }}
          </a>
        </li>
        
        <li>
          <a href="{{ url('pages/contact') }}" class="text-gray-700 hover:text-primary transition font-medium">
            {{ 'contact_us'|trans }}
          </a>
        </li>
      </ul>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t">
    <form action="{{ url('products') }}" method="get" class="p-4 border-b">
      <div class="relative">
        <input 
          type="text" 
          name="search" 
          placeholder="{{ 'search_placeholder'|trans }}" 
          class="w-full px-4 py-2 border border-gray-300 rounded-full focus:outline-none focus:ring-2 focus:ring-primary"
        >
      </div>
    </form>
    <ul class="py-2">
      <li><a href="{{ url('products') }}" class="block px-4 py-2 hover:bg-gray-100">{{ 'shop'|trans }}</a></li>
      <li><a href="{{ url('collections') }}" class="block px-4 py-2 hover:bg-gray-100">{{ 'collections'|trans }}</a></li>
      <li><a href="{{ url('pages/about') }}" class="block px-4 py-2 hover:bg-gray-100">{{ 'about_us'|trans }}</a></li>
      <li><a href="{{ url('pages/contact') }}" class="block px-4 py-2 hover:bg-gray-100">{{ 'contact_us'|trans }}</a></li>
    </ul>
  </div>
</header>

<script>
  // Mobile menu toggle
  document.getElementById('mobile-menu-toggle')?.addEventListener('click', function() {
    const menu = document.getElementById('mobile-menu');
    menu.classList.toggle('hidden');
  });
</script>
